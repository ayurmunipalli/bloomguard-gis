% Hu 2009 FAI — cited in Limitations to explain why FAI was excluded (requires L2 bands)
@article{hu2009fai,
  author  = {Hu, Chuanmin},
  title   = {A novel ocean color index to detect floating algae in the global oceans},
  journal = {Remote Sensing of Environment},
  volume  = {113},
  number  = {10},
  pages   = {2118--2129},
  year    = {2009},
  doi     = {10.1016/j.rse.2009.05.012},
  note    = {VERIFIED: title and sole author (Hu, Chuanmin) confirmed via WebSearch
             2026-07-11; ResearchGate entry + ScienceDirect listing confirm title
             "A novel ocean color index to detect floating algae in the global oceans",
             RSE 113(10):2118--2129, DOI 10.1016/j.rse.2009.05.012. Defines the Floating
             Algae Index (FAI = rho\_rc\_859 - rho\_rc\_645 - (rho\_rc\_1240 - rho\_rc\_645)
             * ((859-645)/(1240-645))). Cited in Limitations: FAI requires MODIS L3m
             bands at ~859 nm and ~1240 nm that are NOT distributed in OB.DAAC L3m
             products; nFLH used as the available L3m fluorescence proxy instead.}
}

